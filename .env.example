# Google Books API (optional — increases rate limits)
# Get a key at https://console.cloud.google.com → APIs → Books API
VITE_GOOGLE_BOOKS_KEY=

# NYT Books API (optional — enables bestseller lists)
# Get a key at https://developer.nytimes.com/get-started
VITE_NYT_KEY=

# Anthropic API (required for AI Review Summary feature)
# Get a key at https://console.anthropic.com
# NOTE: for production, proxy this through your own backend — never ship a key in the browser bundle.
VITE_ANTHROPIC_KEY=
